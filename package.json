{
  "name": "mote-component-library",
  "version": "0.1.0",
  "description": "React component library for Mote products, built on the Mote design system.",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "pack:check": "npm pack --dry-run --cache /tmp/npm-cache"
  },
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "mote-design-system": "^0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.7.0",
    "mote-design-system": "file:../mote-design-system",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
